    "ai": ">=6.0.0",
    "@ai-sdk/provider": ">=1.0.0"
  },
  "devDependencies": {
    "ai": "^6.0.116",
    "@ai-sdk/provider": "^3.0.8",
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  }
